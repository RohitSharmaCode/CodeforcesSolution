#include<bits/stdc++.h>
using namespace std;
bool isPalindrome(long long num) {
    long long original = num, rev = 0;
    while (num > 0) {
        rev = rev * 10 + num % 10;
        num /= 10;
    }
    return original == rev;
}
int main(){
    int t;
    cin>>t;
